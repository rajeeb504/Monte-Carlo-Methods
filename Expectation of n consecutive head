import random


def Expectation_2H(N= 100000):
  
  s = ['H', 'T']
  total = 0

  for _ in range(N):
    toss = 0
    heads = 0
    while heads < 2:
      toss += 1
      if random.choice(s) == 'H':
        heads += 1
      else:
        heads = 0

    total += toss
  
  result = total / N
  
  return result
